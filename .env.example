ENVIRONMENT=local

# GraphQL playground (local subgraph). Change if :4003 is already in use.
# PORT=4003

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
LOCALSTACK_AUTH_TOKEN=replace-with-your-localstack-token

# --- Database (LocalStack RDS) ---
DATABASE_URL=postgres://postgres:POSTGRES@localhost.localstack.cloud:4510/lamdapractice?sslmode=disable

# --- AWS Endpoints ---
AWS_ENDPOINT_URL=http://localstack_project:4566
AWS_LAMBDA_ENDPOINT=http://localhost:4566

# Optional Lambda overrides
# LAMBDA_GET_USER_NAME=getUser
# LAMBDA_LIST_USERS_NAME=listUsers
# LAMBDA_CREATE_USER_NAME=createUser
# LAMBDA_UPDATE_USER_NAME=updateUser
# LAMBDA_DELETE_USER_NAME=deleteUser
# LAMBDA_LOGIN_NAME=login

# Kinesis: audit trail (command Lambdas). CDC stream name matches DMS target in setup_dms_cdc.ps1 (user-cdc-events).
KINESIS_AUDIT_STREAM_NAME=user-audit-events

# CDC: LocalStack Pro DMS -> user-cdc-events -> cdcEventRouter -> SQS -> userEventWorker. docker-compose: ENABLE_DMS=1.
# Order: .\setup_localstack.ps1 -> .\setup_dms_cdc.ps1 -> .\deploy_all.ps1

# USERS_EVENTS_QUEUE_NAME=users-events.fifo

# Auth
JWT_SECRET=replace-with-a-strong-secret
JWT_TTL_MINUTES=60
