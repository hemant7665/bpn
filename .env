ENVIRONMENT=local
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# --- Database (LocalStack RDS) ---
# Used by Lambdas running inside LocalStack containers.
# localhost.localstack.cloud resolves to the RDS instance from within the Lambda container.
DATABASE_URL=postgres://postgres:POSTGRES@localhost.localstack.cloud:4510/lamdapractice?sslmode=disable

# --- AWS Endpoints ---
# For Lambdas (container-to-container): use the container name
AWS_ENDPOINT_URL=http://localstack_project:4566

# For host-to-LocalStack (e.g. running subgraph or tests locally): use localhost
AWS_LAMBDA_ENDPOINT=http://localhost:4566

